<Window x:Class="Fngine.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Fngine"
        mc:Ignorable="d"
		KeyDown="Window_KeyHandler"
		KeyUp="Window_KeyHandler"
        MouseMove="Window_MouseHandler"
        SizeChanged="Window_SizeChangeHandler"
        Background="BlueViolet"
        Title="Fngine" Height="450" Width="800">
    <Grid>
		<StackPanel>
            <Label x:Name="WorldTimer">0.0</Label>
            <Label x:Name="WindowData">-</Label>
            
            <StackPanel Orientation="Horizontal">
                <Label x:Name="MouseX">0.0</Label>
                <Label x:Name="MouseY">0.0</Label>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
				<Label x:Name="PlayerLocationX">0.0</Label>
				<Label x:Name="PlayerLocationY">0.0</Label>
				<Label x:Name="PlayerLocationZ">0.0</Label>
                <Label>Facing: </Label>
                <Label x:Name="PlayerLocationYaw">0.0</Label>
                <Label x:Name="PlayerLocationPitch">0.0</Label>
            </StackPanel>
		</StackPanel>
	</Grid>
</Window>
